{
  "name": "openapoc",
  "version-string": "0.1.0-dev",
  "dependencies": [
    {
      "name": "sdl2",
      "default-features": false,
      "features": [
        { "name": "x11",     "platform": "linux" },
        { "name": "wayland", "platform": "linux" }
      ]
    },
    "boost-locale",
    "boost-program-options",
    "boost-uuid",
    "boost-crc",
    "libvorbis"
  ],
  "features": {
    "launcher": {
      "description": "Build Launcher",
      "dependencies": [
        {
          "name": "qtbase"
        }
      ]
    }
  }
}
